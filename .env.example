# Personal Resume — Environment Variables
#
# 本地开发：复制本文件为 .env.local，填入真实值（.env.local 已在 .gitignore 中）
# 生产构建（CI）：通过 GitHub Actions 的 environment / repository secrets 注入
# 不填时使用占位符，CI build 不会失败，但联系方式显示 "[待配置]"

# 联系邮箱（联系方式区 / mailto: 链接）— 生产请用真实值，本地/示例请留占位符
VITE_PUBLIC_EMAIL=you@example.com

# 手机号（联系方式区 / tel: 链接）— 生产请用真实值，本地/示例请留占位符
VITE_PUBLIC_PHONE=+86-XXX-XXXX-XXXX

# 访问统计后端 URL —— HF Space 部署的后端地址
# 本地开发: VITE_API_BASE=http://localhost:7860
# 生产 (GH Pages): VITE_API_BASE=https://appstoreqaq-personal-resume.hf.space
# 留空 = 关闭埋点（fire-and-forget 静默 no-op）
VITE_API_BASE=
